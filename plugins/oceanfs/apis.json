    "v4.oceanfs.file-system-vpc.bind": {
      "method": "POST",
      "path": "/v4/oceanfs/vpc-bind-permission",
      "content_type": "application/json",
      "body": {
        "isVpce": "$param.is_vpce",
        "permissionGroupFuid": "$param.permission_group_fuid",
        "regionID": "$profile.region",
        "sfsUID": "$param.sfs_uid",
        "subnetID": "$param.subnet_id",
        "vpcID": "$param.vpc_id"
      },
      "retryable": false
    },
    "v4.oceanfs.file-system-vpc.change-permission-group": {
      "method": "POST",
      "path": "/v4/oceanfs/vpc-change-permission",
      "content_type": "application/json",
      "body": {
        "permissionGroupFuid": "$param.permission_group_fuid",
        "regionID": "$profile.region",
        "sfsUID": "$param.sfs_uid",
        "vpcID": "$param.vpc_id"
      },
      "retryable": false
    },
    "v4.oceanfs.file-system-vpc.list": {
      "method": "GET",
      "path": "/v4/oceanfs/list-vpc-permission",
      "content_type": "application/json",
      "query": {
        "regionID": "$profile.region",
        "sfsUID": "$param.sfs_uid"
      },
      "retryable": true
    },
    "v4.oceanfs.file-system-vpc.unbind": {
      "method": "POST",
      "path": "/v4/oceanfs/vpc-unbind-permission",
