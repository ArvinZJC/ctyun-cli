      "path": "/v4/oceanfs/new-sfs",
      "content_type": "application/json",
      "body": {
        "azName": "$param.az_name",
        "clientToken": "$param.client_token",
        "cycleCount": "$param.cycle_count",
        "cycleType": "$param.cycle_type",
        "isVpce": "$param.is_vpce",
        "labelList": "$param.label_list",
        "onDemand": "$param.on_demand",
        "orderNum": "$param.order_num",
        "projectID": "$param.project_id",
        "regionID": "$profile.region",
        "sfsName": "$param.sfs_name",
        "sfsProtocol": "$param.sfs_protocol",
        "sfsSize": "$param.sfs_size",
