{
  "operations": {
    "v4.cdr.client.register": {
      "method": "POST",
      "path": "/v4/disaster/register-client-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.client.reverse-register": {
      "method": "POST",
      "path": "/v4/disaster/back-register-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.client.upgrade": {
      "method": "POST",
      "path": "/v4/disaster/update-client-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.drill.clear": {
      "method": "POST",
      "path": "/v4/disaster/cleare-recovery-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.drill.start": {
      "method": "POST",
      "path": "/v4/disaster/drill-recovery-disaster",
      "content_type": "application/json",
      "body": {
        "drillIp": "$param.drill_ip",
        "ecsID": "$param.ecs_id",
        "favorID": "$param.favor_id",
        "instanceName": "$param.instance_name",
        "pairID": "$param.pair_id",
        "publicIpID": "$param.public_ip_id",
        "regionID": "$profile.region",
        "restoreID": "$param.restore_id",
        "volumeType": "$param.volume_type"
      },
      "retryable": false
    },
    "v4.cdr.failover.confirm": {
      "method": "POST",
      "path": "/v4/disaster/confirm-failover-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.failover.recover": {
      "method": "POST",
      "path": "/v4/disaster/start-recover-disaster",
      "content_type": "application/json",
      "body": {
        "RecoverIp": "$param.recover_ip",
        "ecsID": "$param.ecs_id",
        "favorID": "$param.favor_id",
        "instanceName": "$param.instance_name",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region",
        "volumeType": "$param.volume_type"
      },
      "retryable": false
    },
    "v4.cdr.failover.start": {
      "method": "POST",
      "path": "/v4/disaster/start-failover-disaster",
      "content_type": "application/json",
      "body": {
        "FailoverIp": "$param.failover_ip",
        "ecsID": "$param.ecs_id",
        "favorID": "$param.favor_id",
        "instanceName": "$param.instance_name",
        "pairID": "$param.pair_id",
        "publicIpID": "$param.public_ip_id",
        "regionID": "$profile.region",
        "restoreID": "$param.restore_id",
        "volumeType": "$param.volume_type"
      },
      "retryable": false
    },
    "v4.cdr.network-flow.show": {
      "method": "GET",
      "path": "/v4/disaster/query-flow-disaster",
      "content_type": "application/json",
      "query": {
        "flowHour": "$param.flow_hour",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.cdr.protection-group.create": {
      "method": "POST",
      "path": "/v4/disaster/new-pair-disaster",
      "content_type": "application/json",
      "body": {
        "drillCenter": "$param.drill_center",
        "protectedCenter": "$param.protected_center",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.protection-group.delete": {
      "method": "POST",
      "path": "/v4/disaster/refund-pair-disaster",
      "content_type": "application/json",
      "body": {
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.protection-group.list": {
      "method": "POST",
      "path": "/v4/disaster/info-pair-disaster",
      "content_type": "application/json",
      "body": {
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.cdr.protection-group.show": {
      "method": "GET",
      "path": "/v4/disaster/query-pair-disaster",
      "content_type": "application/json",
      "query": {
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.cdr.protection-group.update": {
      "method": "POST",
      "path": "/v4/disaster/update-pair-disaster",
      "content_type": "application/json",
      "body": {
        "drillName": "$param.drill_name",
        "pairID": "$param.pair_id",
        "protectedName": "$param.protected_name",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.replication.repair": {
      "method": "POST",
      "path": "/v4/disaster/repair-replication-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.replication.restart": {
      "method": "POST",
      "path": "/v4/disaster/restart-replication-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.replication.start": {
      "method": "POST",
      "path": "/v4/disaster/start-replication-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "interruptRestart": "$param.interrupt_restart",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region",
        "restorePointHour": "$param.restore_point_hour",
        "volumeType": "$param.volume_type"
      },
      "retryable": false
    },
    "v4.cdr.replication.stop": {
      "method": "POST",
      "path": "/v4/disaster/stop-replication-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.restore-point.list": {
      "method": "POST",
      "path": "/v4/disaster/restore-point-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.cdr.restore-point.replace": {
      "method": "POST",
      "path": "/v4/disaster/replace-restore-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region",
        "restoreID": "$param.restore_id"
      },
      "retryable": false
    },
    "v4.cdr.reverse-replication.repair": {
      "method": "POST",
      "path": "/v4/disaster/back-repair-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.reverse-replication.restart": {
      "method": "POST",
      "path": "/v4/disaster/back-restart-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.reverse-replication.start": {
      "method": "POST",
      "path": "/v4/disaster/back-replication-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "isOriginal": "$param.is_original",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region",
        "volumeType": "$param.volume_type"
      },
      "retryable": false
    },
    "v4.cdr.reverse-replication.stop": {
      "method": "POST",
      "path": "/v4/disaster/back-stop-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.server.add": {
      "method": "POST",
      "path": "/v4/disaster/new-ecs-disaster",
      "content_type": "application/json",
      "body": {
        "ecsIDs": "$param.ecs_ids",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.server.list": {
      "method": "POST",
      "path": "/v4/disaster/query-ecs-disaster",
      "content_type": "application/json",
      "body": {
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.cdr.server.remove": {
      "method": "POST",
      "path": "/v4/disaster/refund-ecs-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.server.show": {
      "method": "GET",
      "path": "/v4/disaster/info-ecs-disaster",
      "content_type": "application/json",
      "body": {
        "ecsID": "$param.ecs_id",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.cdr.service.enable": {
      "method": "POST",
      "path": "/v4/disaster/open-service-disaster",
      "content_type": "application/json",
      "body": {
        "clientToken": "$param.client_token",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.cdr.task.list": {
      "method": "POST",
      "path": "/v4/disaster/query-task-disaster",
      "content_type": "application/json",
      "body": {
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "pairID": "$param.pair_id",
        "regionID": "$profile.region",
        "taskID": "$param.task_id"
      },
      "retryable": true
    },
    "v4.cdr.task.show": {
      "method": "GET",
      "path": "/v4/disaster/info-task-disaster",
      "content_type": "application/json",
      "query": {
        "regionID": "$profile.region",
        "taskID": "$param.task_id"
      },
      "retryable": true
    }
  }
}
