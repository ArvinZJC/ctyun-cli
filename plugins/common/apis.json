{
  "operations": {
    "v4.common.ecs-flavor.list": {
      "method": "GET",
      "path": "/v4/common/get-ecs-flavors",
      "content_type": "application/json",
      "query": {
        "azName": "$param.az_name",
        "regionID": "$profile.region",
        "series": "$param.series"
      },
      "retryable": true
    }
  }
}
