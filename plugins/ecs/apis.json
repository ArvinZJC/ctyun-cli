{
  "operations": {
    "v4.ecs.instance.list": {
      "method": "POST",
      "path": "/v4/ecs/list-instances",
      "content_type": "application/json",
      "retryable": true,
      "body": {
        "regionID": "$profile.region",
        "keyword": "$param.name"
      }
    },
    "v4.ecs.instance.show": {
      "method": "GET",
      "path": "/v4/ecs/instance-details",
      "content_type": "application/json",
      "retryable": true,
      "query": {
        "regionID": "$profile.region",
        "instanceID": "$arg.instance_id"
      }
    },
    "v4.ecs.instance.start": {
      "method": "POST",
      "path": "/v4/ecs/start-instance",
      "content_type": "application/json",
      "body": {
        "regionID": "$profile.region",
        "instanceID": "$arg.instance_id"
      }
    }
  }
}
