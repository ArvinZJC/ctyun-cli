{
  "operations": {
    "v4.ims.image.copy": {
      "method": "POST",
      "path": "/v4/image/copy",
      "content_type": "application/json",
      "body": {
        "cmkID": "$param.cmk_id",
        "description": "$param.description",
        "imageID": "$arg.image_id",
        "imageName": "$param.image_name",
        "labels": "$param.labels",
        "projectID": "$param.project_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.create-from-data-disk": {
      "method": "POST",
      "path": "/v4/image/create-from-data-disk",
      "content_type": "application/json",
      "body": {
        "dataDiskID": "$param.data_disk_id",
        "description": "$param.description",
        "enableImageIntegrityCheck": "$param.enable_image_integrity_check",
        "imageName": "$param.image_name",
        "instanceID": "$param.instance_id",
        "labels": "$param.labels",
        "projectID": "$param.project_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.create-from-ecs": {
      "method": "POST",
      "path": "/v4/image/create-from-ecs",
      "content_type": "application/json",
      "body": {
        "description": "$param.description",
        "imageName": "$param.image_name",
        "instanceID": "$param.instance_id",
        "labels": "$param.labels",
        "projectID": "$param.project_id",
        "regionID": "$profile.region",
        "repositoryID": "$param.repository_id"
      },
      "retryable": false
    },
    "v4.ims.image.create-from-shared": {
      "method": "POST",
      "path": "/v4/image/create-from-shared",
      "content_type": "application/json",
      "body": {
        "description": "$param.description",
        "imageID": "$arg.image_id",
        "imageName": "$param.image_name",
        "labels": "$param.labels",
        "projectID": "$param.project_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.create-from-snapshot": {
      "method": "POST",
      "path": "/v4/image/create-from-ecs-snapshot",
      "content_type": "application/json",
      "body": {
        "description": "$param.description",
        "enableImageIntegrityCheck": "$param.enable_image_integrity_check",
        "imageName": "$param.image_name",
        "labels": "$param.labels",
        "maximumRAM": "$param.maximum_ram",
        "minimumRAM": "$param.minimum_ram",
        "projectID": "$param.project_id",
        "regionID": "$profile.region",
        "snapshotID": "$param.snapshot_id"
      },
      "retryable": false
    },
    "v4.ims.image.create-from-system-disk": {
      "method": "POST",
      "path": "/v4/image/create",
      "content_type": "application/json",
      "body": {
        "description": "$param.description",
        "enableImageIntegrityCheck": "$param.enable_image_integrity_check",
        "imageName": "$param.image_name",
        "instanceID": "$param.instance_id",
        "labels": "$param.labels",
        "maximumRAM": "$param.maximum_ram",
        "minimumRAM": "$param.minimum_ram",
        "projectID": "$param.project_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.cross-region-copy": {
      "method": "POST",
      "path": "/v4/image/cross-region-copy",
      "content_type": "application/json",
      "body": {
        "description": "$param.description",
        "destinationRegionID": "$param.destination_region_id",
        "imageID": "$arg.image_id",
        "imageName": "$param.image_name",
        "labels": "$param.labels",
        "projectID": "$param.project_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.deactivate": {
      "method": "POST",
      "path": "/v4/image/deactivate",
      "content_type": "application/json",
      "query": {
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.delete": {
      "method": "POST",
      "path": "/v4/image/delete",
      "content_type": "application/json",
      "body": {
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.export": {
      "method": "POST",
      "path": "/v4/image/export",
      "content_type": "application/json",
      "body": {
        "bucket": "$param.bucket",
        "filename": "$param.filename",
        "imageFileFormat": "$param.image_file_format",
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.import": {
      "method": "POST",
      "path": "/v4/image/import",
      "content_type": "application/json",
      "body": {
        "enableImageIntegrityCheck": "$param.enable_image_integrity_check",
        "imageFileSource": "$param.image_file_source",
        "imageProperties": "$param.image_properties",
        "labels": "$param.labels",
        "projectID": "$param.project_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.list": {
      "method": "GET",
      "path": "/v4/image/list",
      "content_type": "application/json",
      "query": {
        "azName": "$param.az_name",
        "cwaiType": "$param.cwai_type",
        "flavorName": "$param.flavor_name",
        "imageName": "$param.image_name",
        "imageScene": "$param.image_scene",
        "imageStatus": "$param.image_status",
        "imageSubcategory": "$param.image_subcategory",
        "imageType": "$param.image_type",
        "imageVisibilityCode": "$param.image_visibility_code",
        "osTypeCode": "$param.os_type_code",
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "projectID": "$param.project_id",
        "queryContent": "$param.query_content",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.ims.image.reactivate": {
      "method": "POST",
      "path": "/v4/image/reactivate",
      "content_type": "application/json",
      "query": {
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.image.show": {
      "method": "GET",
      "path": "/v4/image/detail",
      "content_type": "application/json",
      "query": {
        "errorFree": "$param.error_free",
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.ims.image.update": {
      "method": "POST",
      "path": "/v4/image/update",
      "content_type": "application/json",
      "body": {
        "bootMode": "$param.boot_mode",
        "description": "$param.description",
        "imageID": "$arg.image_id",
        "imageName": "$param.image_name",
        "maximumRAM": "$param.maximum_ram",
        "minimumRAM": "$param.minimum_ram",
        "regionID": "$profile.region",
        "supportXSSD": "$param.support_xssd"
      },
      "retryable": false
    },
    "v4.ims.image.validate-file-source": {
      "method": "GET",
      "path": "/v4/image/validate-file-source",
      "content_type": "application/json",
      "query": {
        "imageFileSource": "$param.image_file_source",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.ims.import-task.delete": {
      "method": "POST",
      "path": "/v4/image/delete-import-task",
      "content_type": "application/json",
      "query": {
        "regionID": "$profile.region",
        "taskID": "$arg.task_id"
      },
      "retryable": false
    },
    "v4.ims.import-task.list": {
      "method": "GET",
      "path": "/v4/image/list-import-tasks",
      "content_type": "application/json",
      "query": {
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.ims.label.update": {
      "method": "POST",
      "path": "/v4/image/update-labels",
      "content_type": "application/json",
      "body": {
        "imageIDList": "$param.image_id_list",
        "labels": "$param.labels",
        "operateType": "$param.operate_type",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.region.list-copy-destinations": {
      "method": "GET",
      "path": "/v4/image/list-supported-dest-crr-regions",
      "content_type": "application/json",
      "query": {
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.ims.share.accept": {
      "method": "POST",
      "path": "/v4/image/shared-image/accept",
      "content_type": "application/json",
      "body": {
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.share.create": {
      "method": "POST",
      "path": "/v4/image/shared-image/create",
      "content_type": "application/json",
      "body": {
        "destinationAccountID": "$param.destination_account_id",
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.share.delete": {
      "method": "POST",
      "path": "/v4/image/shared-image/delete",
      "content_type": "application/json",
      "body": {
        "cancelAllSharedAccount": "$param.cancel_all_shared_account",
        "destinationAccountID": "$param.destination_account_id",
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.share.list": {
      "method": "GET",
      "path": "/v4/image/show-shared-list",
      "content_type": "application/json",
      "query": {
        "imageID": "$arg.image_id",
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "regionID": "$profile.region"
      },
      "retryable": true
    },
    "v4.ims.share.reject": {
      "method": "POST",
      "path": "/v4/image/shared-image/reject",
      "content_type": "application/json",
      "body": {
        "imageID": "$arg.image_id",
        "regionID": "$profile.region"
      },
      "retryable": false
    },
    "v4.ims.task.action": {
      "method": "POST",
      "path": "/v4/image/action-task",
      "content_type": "application/json",
      "body": {
        "action": "$param.action",
        "regionID": "$profile.region",
        "taskID": "$arg.task_id"
      },
      "retryable": false
    },
    "v4.ims.task.list": {
      "method": "POST",
      "path": "/v4/image/list-tasks",
      "content_type": "application/json",
      "body": {
        "action": "$param.action",
        "imageID": "$arg.image_id",
        "pageNo": "$param.page_no",
        "pageSize": "$param.page_size",
        "regionID": "$profile.region",
        "taskStatus": "$param.task_status"
      },
      "retryable": true
    }
  }
}
