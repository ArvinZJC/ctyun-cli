{
  "operations": {
    "v4.order.new.price": {
      "method": "POST",
      "path": "/v4/new-order/query-price",
      "content_type": "application/json",
      "body": {
        "azName": "$param.az_name",
        "bandwidth": "$param.bandwidth",
        "cbrValue": "$param.cbr_value",
        "count": "$param.count",
        "cycleCount": "$param.cycle_count",
        "cycleType": "$param.cycle_type",
        "deviceType": "$param.device_type",
        "diskMode": "$param.disk_mode",
        "diskSize": "$param.disk_size",
        "diskType": "$param.disk_type",
        "disks": "$param.disks",
        "elbType": "$param.elb_type",
        "flavorName": "$param.flavor_name",
        "imageUUID": "$param.image_uuid",
        "ipPoolBandwidth": "$param.ip_pool_bandwidth",
        "natType": "$param.nat_type",
        "onDemand": "$param.on_demand",
        "orderDisks": "$param.order_disks",
        "regionID": "$profile.region",
        "resourceType": "$param.resource_type",
        "sysDiskSize": "$param.sys_disk_size",
        "sysDiskType": "$param.sys_disk_type"
      },
      "retryable": true
    },
    "v4.order.price.new": {
      "method": "POST",
      "path": "/v4/order/new-query-price",
      "content_type": "application/json",
      "body": {
        "azName": "$param.az_name",
        "bandwidth": "$param.bandwidth",
        "cbrValue": "$param.cbr_value",
        "count": "$param.count",
        "cycleCount": "$param.cycle_count",
        "cycleType": "$param.cycle_type",
        "deviceType": "$param.device_type",
        "diskMode": "$param.disk_mode",
        "diskSize": "$param.disk_size",
        "diskType": "$param.disk_type",
        "disks": "$param.disks",
        "elbType": "$param.elb_type",
        "flavorName": "$param.flavor_name",
        "imageUUID": "$param.image_uuid",
        "ipPoolBandwidth": "$param.ip_pool_bandwidth",
        "natType": "$param.nat_type",
        "onDemand": "$param.on_demand",
        "orderDisks": "$param.order_disks",
        "regionID": "$profile.region",
        "resourceType": "$param.resource_type",
        "sysDiskSize": "$param.sys_disk_size",
        "sysDiskType": "$param.sys_disk_type"
      },
      "retryable": true
    },
    "v4.order.price.renew": {
      "method": "POST",
      "path": "/v4/order/renew-query-price",
      "content_type": "application/json",
      "body": {
        "cycleCount": "$param.cycle_count",
        "cycleType": "$param.cycle_type",
        "regionID": "$profile.region",
        "resourceType": "$param.resource_type",
        "resourceUUID": "$param.resource_uuid"
      },
      "retryable": true
    },
    "v4.order.price.upgrade": {
      "method": "POST",
      "path": "/v4/order/upgrade-query-price",
      "content_type": "application/json",
      "body": {
        "bandwidth": "$param.bandwidth",
        "cbrValue": "$param.cbr_value",
        "diskSize": "$param.disk_size",
        "elbType": "$param.elb_type",
        "flavorName": "$param.flavor_name",
        "ipPoolBandwidth": "$param.ip_pool_bandwidth",
        "natType": "$param.nat_type",
        "regionID": "$profile.region",
        "resourceType": "$param.resource_type",
        "resourceUUID": "$param.resource_uuid"
      },
      "retryable": true
    },
    "v4.order.renew.price": {
      "method": "POST",
      "path": "/v4/renew-order/query-price",
      "content_type": "application/json",
      "body": {
        "cycleCount": "$param.cycle_count",
        "cycleType": "$param.cycle_type",
        "regionID": "$profile.region",
        "resourceID": "$param.resource_id",
        "resourceType": "$param.resource_type"
      },
      "retryable": true
    },
    "v4.order.resource-uuid.list": {
      "method": "GET",
      "path": "/v4/order/query-uuid",
      "content_type": "application/json",
      "query": {
        "masterOrderId": "$arg.master_order_id"
      },
      "retryable": true
    },
    "v4.order.upgrade.price": {
      "method": "POST",
      "path": "/v4/upgrade-order/query-price",
      "content_type": "application/json",
      "body": {
        "bandwidth": "$param.bandwidth",
        "cbrValue": "$param.cbr_value",
        "diskSize": "$param.disk_size",
        "elbType": "$param.elb_type",
        "flavorName": "$param.flavor_name",
        "ipPoolBandwidth": "$param.ip_pool_bandwidth",
        "natType": "$param.nat_type",
        "regionID": "$profile.region",
        "resourceID": "$param.resource_id",
        "resourceType": "$param.resource_type"
      },
      "retryable": true
    }
  }
}
