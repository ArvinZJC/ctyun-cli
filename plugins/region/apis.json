{
  "operations": {
    "v4.region.demand.check": {
      "method": "GET",
      "path": "/v4/region/check-demand",
      "content_type": "application/json",
      "query": {
        "azName": "$param.azName",
        "ebsSize": "$param.ebsSize",
        "ebsType": "$param.ebsType",
        "ecsAmount": "$param.ecsAmount",
        "eipAmount": "$param.eipAmount",
        "flavorID": "$param.flavorID",
        "productType": "$param.productType",
        "regionID": "$arg.region_id",
        "specName": "$param.specName"
      },
      "retryable": true,
      "accepted_statuses": [
        {
          "code": "900",
          "required_path": "returnObj.satisfied"
        }
      ]
    },
    "v4.region.list": {
      "method": "GET",
      "path": "/v4/region/list-regions",
      "content_type": "application/json",
      "query": {
        "regionName": "$param.regionName"
      },
      "retryable": true
    },
    "v4.region.product.show": {
      "method": "GET",
      "path": "/v4/region/get-products",
      "content_type": "application/json",
      "query": {
        "regionID": "$arg.region_id"
      },
      "retryable": true
    },
    "v4.region.quota.show": {
      "method": "GET",
      "path": "/v4/region/customer-quotas",
      "content_type": "application/json",
      "query": {
        "regionID": "$arg.region_id"
      },
      "retryable": true
    },
    "v4.region.resource.show": {
      "method": "GET",
      "path": "/v4/region/customer-resources",
      "content_type": "application/json",
      "query": {
        "regionID": "$arg.region_id"
      },
      "retryable": true
    },
    "v4.region.show": {
      "method": "GET",
      "path": "/v4/region/get-summary",
      "content_type": "application/json",
      "query": {
        "regionID": "$arg.region_id"
      },
      "retryable": true
    },
    "v4.region.zone.list": {
      "method": "GET",
      "path": "/v4/region/get-zones",
      "content_type": "application/json",
      "query": {
        "regionID": "$arg.region_id"
      },
      "retryable": true
    }
  }
}
