{
  "operations": {
    "v4.region.list": {
      "method": "GET",
      "path": "/v4/region/list-regions",
      "content_type": "application/json",
      "retryable": true,
      "query": {
        "regionName": "$param.regionName"
      }
    },
    "v4.region.show": {
      "method": "GET",
      "path": "/v4/region/get-summary",
      "content_type": "application/json",
      "retryable": true,
      "query": {
        "regionID": "$arg.region_id"
      }
    },
    "v4.region.zone.list": {
      "method": "GET",
      "path": "/v4/region/get-zones",
      "content_type": "application/json",
      "retryable": true,
      "query": {
        "regionID": "$arg.region_id"
      }
    },
    "v4.region.product.show": {
      "method": "GET",
      "path": "/v4/region/get-products",
      "content_type": "application/json",
      "retryable": true,
      "query": {
        "regionID": "$arg.region_id"
      }
    },
    "v4.region.demand.check": {
      "method": "GET",
      "path": "/v4/region/check-demand",
      "content_type": "application/json",
      "retryable": true,
      "query": {
        "regionID": "$arg.region_id",
        "productType": "$param.productType",
        "azName": "$param.azName",
        "flavorID": "$param.flavorID",
        "specName": "$param.specName",
        "ecsAmount": "$param.ecsAmount",
        "ebsType": "$param.ebsType",
        "ebsSize": "$param.ebsSize",
        "eipAmount": "$param.eipAmount"
      }
    }
  }
}
